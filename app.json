{
  "expo": {
    "name": "ZZ Admin",
    "slug": "zapzone-analytics-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/zapzone-assests/ZZ-icon.png",
    "scheme": "zapzoneanalyticsapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/zapzone-assests/ZZ-icon.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.zapzone.analytics"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/zapzone-assests/zapzone.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ZapZone to access your camera to scan ticket QR codes for check-in.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow ZapZone to save booking QR codes to your photos.",
          "savePhotosPermission": "Allow ZapZone to save booking QR codes to your photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60075b7b-a0bf-48e3-ae9b-1d4701778c40"
      }
    },
    "owner": "rlndcsr"
  }
}
