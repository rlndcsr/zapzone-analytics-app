EXPO_PUBLIC_API_URL=https://backend-url.com
# Public web (Zappoint) origin where customers open purchase pages. This is the
# frontend host, NOT the backend API above. Used to build purchase links such as
# https://booking.zap-zone.com/purchase/attraction/<location>/<slug>. If unset,
# purchase links fall back to the API origin (structurally correct, wrong host).
EXPO_PUBLIC_WEB_URL=https://booking.zap-zone.com
